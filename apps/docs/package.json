{
  "name": "docs",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "bench:pilot": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --execute=true --include-cloud=false --model-id=composer-2",
    "bench:pilot:step": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --execute=true --include-cloud=false --model-id=composer-2 --sequential-step=true",
    "bench:pilot:step:reset": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --sequential-step=false --reset-sequential-step=true",
    "bench:pilot:practical:step": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --task-manifest=tasks-manifest.practical.json --execute=true --include-cloud=false --model-id=composer-2 --sequential-step=true --sequential-step-state-path=benchmarks/.pilot-practical-sequential-step.json",
    "bench:pilot:practical:step:strict": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --task-manifest=tasks-manifest.practical.json --execute=true --include-cloud=false --model-id=composer-2 --sequential-step=true --sequential-step-require-correctness=true --sequential-step-state-path=benchmarks/.pilot-practical-sequential-step.json",
    "bench:pilot:practical:step:reset": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --task-manifest=tasks-manifest.practical.json --sequential-step=false --reset-sequential-step=true --sequential-step-state-path=benchmarks/.pilot-practical-sequential-step.json",
    "bench:full": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=full --execute=true --include-cloud=true --model-id=composer-2",
    "bench:full:practical": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=full --task-manifest=tasks-manifest.practical.json --execute=true --include-cloud=false --model-id=composer-2",
    "bench:prepare": "dotenv -e .env -- tsx benchmarks/benchmark-cli.ts --mode=pilot --execute=false --include-cloud=false --model-id=composer-2",
    "bench:clean": "tsx scripts/benchmark-clean.ts",
    "test:benchmarks": "vitest run benchmarks/__tests__",
    "sync:nci-first-agent-primer": "tsx scripts/sync-nci-first-agent-primer.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "@repo/benchmark-contract": "workspace:*",
    "@repo/ui": "workspace:*",
    "next": "16.1.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@pulumi/aws": "7.8.0",
    "@pulumi/pulumi": "3.159.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "5.0.6",
    "@types/lodash": "4.17.24",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "better-auth": "1.4.6",
    "dotenv-cli": "^11.0.0",
    "effect": "3.21.2",
    "eslint": "^9.39.1",
    "expo": "54.0.25",
    "expo-camera": "17.0.9",
    "express": "5.2.1",
    "lodash": "4.18.1",
    "pnpm": "10.33.2",
    "react-hook-form": "7.74.0",
    "swr": "2.4.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "uuid": "14.0.0",
    "vitest": "^3.2.4"
  }
}
