{
  "name": "native-context-modules",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"{apps,packages,tooling,scripts}/**/*.{ts,tsx,md}\" \"!packages/nci-core/fixtures/**/*.d.ts\"",
    "format:check": "prettier --check \"{apps,packages,tooling,scripts}/**/*.{ts,tsx,md}\" \"!packages/nci-core/fixtures/**/*.d.ts\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "prebuild": "pnpm run release:sync-versions && pnpm run sync:skill-primer",
    "release:sync-versions": "tsx scripts/sync-publish-versions.ts",
    "release:verify-versions": "tsx scripts/verify-publish-versions.ts",
    "sync:skill-primer": "tsx packages/nci-agent-primer/scripts/sync-skill-primer.ts",
    "rust:fmt:check": "cargo fmt --all -- --check",
    "rust:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:test:lib": "cargo test -p nci-engine --lib",
    "rust:test:snapshots": "cargo test -p nci-engine --test snapshot_tests",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14",
    "typescript": "5.9.2",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
