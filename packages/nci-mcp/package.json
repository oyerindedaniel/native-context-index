{
  "name": "@nativecontextindex/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol (stdio) server for the Native Context Index (nci)",
  "author": "Oyerinde Daniel",
  "license": "Apache-2.0",
  "homepage": "https://nativecontextindex.com",
  "bugs": {
    "url": "https://github.com/oyerindedaniel/native-context-index/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oyerindedaniel/native-context-index.git"
  },
  "keywords": [
    "nci",
    "mcp",
    "model-context-protocol",
    "typescript",
    "declarations"
  ],
  "type": "commonjs",
  "bin": {
    "nci-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@repo/nci-agent-primer": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
