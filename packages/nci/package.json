{
  "name": "@nativecontextindex/cli",
  "version": "0.1.0",
  "description": "Native Context Index CLI (downloads prebuilt binary from GitHub Releases on install)",
  "author": "Oyerinde Daniel",
  "license": "Apache-2.0",
  "homepage": "https://nativecontextindex.com",
  "bugs": {
    "url": "https://github.com/oyerindedaniel/native-context-index/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oyerindedaniel/native-context-index.git"
  },
  "keywords": [
    "nci",
    "typescript",
    "declarations",
    "cli",
    "indexing"
  ],
  "bin": {
    "nci": "dist/bin/nci.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
