{
  "name": "conditional-exports-pkg",
  "version": "1.0.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts"
    }
  },
  "typesVersions": {
    ">=1.0": {
      ".": ["dist/index.d.ts"]
    }
  }
}
