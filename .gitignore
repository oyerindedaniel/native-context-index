# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies (ignore workspace installs; tracked fixture vendor trees under packages/nci-core/fixtures)
node_modules/
!packages/nci-core/fixtures/**/node_modules/
!packages/nci-core/fixtures/**/node_modules/**/*
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
# Only root + direct packages/*/ (keeps packages/nci-core/fixtures/**/dist/ committable for tests)
/build/
/packages/*/build/
/dist/
/packages/*/dist/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# NCI Generated / Temp
NCI_ROADMAP.md
NCI_PROPOSAL.md
poc-oracle.ts
nco-react-index.json
**/nci-report.json
**/nci-report-rust.json
packages/nci-core/docs/
docs/

# nci npm: downloaded native binary (postinstall)
packages/nci/vendor/

# Rust build artifacts
/target/

# Backup files from `cargo fix` or other tools
**/*.rs.bk

# Snapshots (pending insta updates only — committed .snap + oracle live under packages/nci-engine/tests/snapshots/)
/snapshots/
**/*.snap.new
snapshot.md

context_summary.md
*.txt
rust-pelumi

